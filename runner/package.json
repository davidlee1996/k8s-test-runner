{
  "name": "k8s-test-runner",
  "version": "0.2.0",
  "description": "Playwright runner for distributed test execution on Kubernetes",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:trace": "playwright test --trace on",
    "upload": "node upload-results.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "devDependencies": {
    "@playwright/test": "1.49.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}